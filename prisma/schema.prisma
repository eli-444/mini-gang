// ==========================
//  DATABASE
// ==========================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================
//  MODELS
// ==========================

// --- NextAuth v5 compatible ---
model User {
  id              String          @id @default(cuid())
  name            String?
  email           String?         @unique
  emailVerified   DateTime?
  image           String?

  accounts        Account[]
  sessions        Session[]
  addresses       Adresse[]
  commandes       Commande[]
  depots          Depot[]
  favoris         Favoris[]
  cagnotte        Cagnotte?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String  @unique
  expires    DateTime

  @@unique([identifier, token])
}


// ==========================
//  E-COMMERCE
// ==========================

model Produit {
  id           String         @id @default(cuid())
  title        String
  slug         String         @unique
  description  String?
  price        Int            // en centimes
  etat         String         // neuf / très bon état / bon état
  taille       String?
  marque       String?
  stock        Int            @default(1)
  images       String[]       

  categorieId  String?
  categorie    Categorie?     @relation(fields: [categorieId], references: [id])

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  favoris      Favoris[]
  lignes       LigneCommande[]
}

model Categorie {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique

  produits  Produit[]
}

model Commande {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  
  total         Int             
  stripeId      String?         

  adresseId     String?
  adresse       Adresse?        @relation(fields: [adresseId], references: [id])

  lignes        LigneCommande[]
  
  createdAt     DateTime        @default(now())
}

model LigneCommande {
  id          String     @id @default(cuid())
  commandeId  String
  produitId   String
  quantity    Int        @default(1)
  price       Int        

  commande    Commande   @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produit     Produit    @relation(fields: [produitId], references: [id])
}

model Adresse {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])

  fullName    String
  line1       String
  line2       String?
  city        String
  postalCode  String
  country     String

  commandes   Commande[]  // <-- AJOUT OBLIGATOIRE

  createdAt   DateTime   @default(now())
}



// ==========================
//  FAVORIS
// ==========================

model Favoris {
  id        String   @id @default(cuid())
  userId    String
  produitId String

  user      User     @relation(fields: [userId], references: [id])
  produit   Produit  @relation(fields: [produitId], references: [id])

  @@unique([userId, produitId])
}


// ==========================
//  CAGNOTTE
// ==========================

model Cagnotte {
  id        String            @id @default(cuid())
  userId    String            @unique
  balance   Int               @default(0)

  mouvements MouvementCagnotte[]

  user      User              @relation(fields: [userId], references: [id])
}

model MouvementCagnotte {
  id          String    @id @default(cuid())
  cagnotteId  String
  amount      Int       
  type        String    
  description String?
  createdAt   DateTime  @default(now())

  cagnotte    Cagnotte  @relation(fields: [cagnotteId], references: [id])
}


// ==========================
//  DÉPÔT (Vendre au Mini Gang)
// ==========================

model Depot {
  id        String          @id @default(cuid())
  userId    String
  status    String          @default("en_attente")
  createdAt DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id])
  articles  ArticleDepose[]
  estimation Estimation?
}

model ArticleDepose {
  id        String   @id @default(cuid())
  depotId   String
  title     String
  marque    String?
  taille    String?
  etat      String?
  image     String?
  priceUser Int?

  depot     Depot    @relation(fields: [depotId], references: [id])
}

model Estimation {
  id         String    @id @default(cuid())
  depotId    String    @unique
  montant    Int       
  bonus      Int       
  total      Int       

  depot      Depot     @relation(fields: [depotId], references: [id])
}
